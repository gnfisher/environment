# Font
#font-family = Cascadia Mono
font-size = 13
#font-thicken = true

# macOS options
macos-option-as-alt = true

# Clipboard
clipboard-read = allow
clipboard-write = allow

# Split panes (match WezTerm)
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Navigate panes (match WezTerm)
keybind = cmd+shift+h=goto_split:left
keybind = cmd+shift+l=goto_split:right
keybind = cmd+shift+k=goto_split:top
keybind = cmd+shift+j=goto_split:bottom

# Close pane
keybind = cmd+w=close_surface

# Shift+Enter for multi-line input in TUIs
keybind = shift+enter=text:\n
theme = Builtin Light