{
  "mcpServers": {
    "datadog": {
      "type": "http",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core,ddsql",
      "tools": [
        "*"
      ]
    },
    "splunk": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SPLUNK_HOST=splunkazure-api-azure-eastus.octoca.ts.net",
        "-e",
        "SPLUNK_PORT=443",
        "-e",
        "SPLUNK_BEARER_TOKEN",
        "-e",
        "SPLUNK_SCHEME=https",
        "-e",
        "VERIFY_SSL=true",
        "-e",
        "FASTMCP_LOG_LEVEL=DEBUG",
        "ghcr.io/github/splunk-mcp-server:latest"
      ]
    }
  }
}
