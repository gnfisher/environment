{
  "renderMarkdown": true,
  "screenReader": false,
  "theme": "dark",
  "allowedUrls": [
    "https://docs.github.com",
    "https://raw.githubusercontent.com",
    "https://gist.github.com",
    "https://gist.githubusercontent.com"
  ],
  "showReasoning": false,
  "experimental": true,
  "logLevel": "all",
  "model": "gpt-5.5",
  "remoteSessions": false,
  "exportSessions": false,
  "steerableSessions": false,
  "storeSessionsRemotely": false,
  "undo_without_confirmation": true,
  "sessionSync": [
    {
      "origin": "*",
      "level": "local"
    }
  ],
  "enabledPlugins": {
    "slack-mcp@github-slack-mcp": true
  },
  "colorMode": "default",
  "extraKnownMarketplaces": {
    "github-slack-mcp": {
      "source": {
        "source": "github",
        "repo": "github/copilot-slack-mcp"
      }
    }
  },
  "ide": {
    "autoConnect": true
  },
  "effortLevel": "xhigh"
}
