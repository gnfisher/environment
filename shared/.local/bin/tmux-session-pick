#!/usr/bin/env bash
set -euo pipefail

if [[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/bash/fzf-theme.bash" ]]; then
    # shellcheck disable=SC1090
    source "${XDG_CONFIG_HOME:-$HOME/.config}/bash/fzf-theme.bash"
fi

if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux is required" >&2
    exit 1
fi
if ! command -v fzf >/dev/null 2>&1; then
    echo "fzf is required" >&2
    exit 1
fi

selection=$(
    tmux list-sessions -F '#S' 2>/dev/null \
        | fzf --reverse --prompt 'session> '
)

[[ -n "$selection" ]] || exit 0
exec tmux switch-client -t "$selection"
