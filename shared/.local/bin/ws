#!/usr/bin/env bash
set -euo pipefail

# ws - Copilot worktree manager
#
# Conventions:
# - Worktrees live under ~/.copilot/copilot-worktrees/<repo>/...
# - PR worktrees: <repo>/pr-<number>
# - Named worktrees: <repo>/<user>/<session-slug>

WORKTREE_BASE="${WS_WORKTREE_BASE:-$HOME/.copilot/copilot-worktrees}"
COPILOT_DB="${WS_COPILOT_DB:-$HOME/.copilot/data.db}"
WS_USER="${WS_USER:-$USER}"
WS_OPEN_MODE="${WS_OPEN_MODE:-ghostty}"
WS_STATE_DIR="${WS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/ws}"
WS_BLESSED_CODESPACE_STATE="${WS_BLESSED_CODESPACE_STATE:-$WS_STATE_DIR/blessed-codespace.json}"
WS_CODESPACE_REPO_MAP="${WS_CODESPACE_REPO_MAP:-$WS_STATE_DIR/codespace-repos.tsv}"
WS_CODESPACE_REMOTE_ROOT="${WS_CODESPACE_REMOTE_ROOT:-/workspace}"
WS_CODESPACE_WEB_PORTS="${WS_CODESPACE_WEB_PORTS:-80 2206 2208 2210 3011 8091 8088}"

REPO_ORG=""
REPO_NAME=""
REPO_DIR=""
REPO_WT_DIR=""
LOCK_PATH=""

show_help() {
    cat << 'EOF'
ws - Copilot worktree manager

Usage: ws <command> [options]

Commands:
  new <session-slug>        Create named worktree from default branch
  new --pr <n|url>          Create/reuse PR worktree (pr-<number>)
  pr <n|url>                Shortcut for: ws new --pr <n|url>
  open <name|path>          Print an existing worktree path for shell cd wrappers
  path <name|path>          Print the resolved worktree path
  pick                      Pick a worktree with fzf and open it
  list                      List managed worktrees for current repo (default: simple view)
  list --all                List managed worktrees across repos
  list --full               Include path + Copilot session metadata
  list --json               Emit JSON for scripts/fzf/Raycast
  delete [--force] <...>    Remove one or more managed worktrees
  clean                     Remove all managed worktrees for current repo
  cs <command>              Manage the blessed dotcom Codespace

Notes:
  - Source repo is resolved from ~/Development/<owner>/<repo> when needed.
  - In fish, 'ws open <name>' changes directory via the shell wrapper.
  - Set WS_OPEN_MODE=print to make new/pr print paths instead of launching Ghostty.
  - Use ws cs bless to choose one mothership Codespace for repo sync.

Options:
  -h, --help    Show this help message

Examples:
  ws new oauth-refresh-investigation
  ws pr 426638
  ws new --pr https://github.com/github/github/pull/426638
  ws open pr-426638
  cd "$(ws path pr-426638)"
  ws pick
  ws list
  ws list --full
  ws list --all --json
  ws delete pr-426638 gnfisher/other-session
  ws cs bless
  ws cs sync
EOF
}

show_cs_help() {
    cat << 'EOF'
ws cs - blessed dotcom Codespace workflow

Usage: ws cs <command> [options]

Commands:
  bless [codespace]        Save/select the mothership Codespace
  status                   Show local branch and remote checkout status
  sync [--force-remote]    Push local HEAD and update /workspace/<repo>
  ssh [command...]         SSH into the blessed Codespace
  repo                     SSH into the matching remote repo directory
  ports [options...]       List ports for the blessed Codespace
  forward <remote>:<local> Forward ports in the foreground
  web-ports [action]       Toggle browser-facing github/github ports

Web port actions:
  toggle                   Start if stopped; stop if running (default)
  start                    Start managed forwarding in the background
  stop                     Stop the managed forwarder started by ws
  status, --status         Show managed forwarding status

State:
  ~/.local/state/ws/blessed-codespace.json by default

Overrides:
  WS_BLESSED_CODESPACE     Temporary Codespace name override
  WS_CODESPACE_REMOTE_PATH Override remote path for current repo
  WS_CODESPACE_REMOTE_ROOT Remote root; defaults to /workspace
  WS_CODESPACE_REPO_MAP    TSV mapping file: owner/repo<TAB>/remote/path
  WS_CODESPACE_WEB_PORTS   Space-separated remote ports to forward locally
EOF
}

log() { echo "==> $*" >&2; }
error() { echo "Error: $*" >&2; }

cleanup_lock() {
    if [[ -n "${LOCK_PATH:-}" ]]; then
        rmdir "$LOCK_PATH" 2>/dev/null || true
    fi
}

canonical_dir() {
    local dir="$1"
    (cd "$dir" 2>/dev/null && pwd -P)
}

canonical_path_maybe() {
    local path="$1"
    if [[ -d "$path" ]]; then
        canonical_dir "$path"
        return 0
    fi

    local parent base
    parent=$(dirname "$path")
    base=$(basename "$path")
    if [[ -d "$parent" ]]; then
        printf '%s/%s\n' "$(canonical_dir "$parent")" "$base"
    else
        printf '%s\n' "$path"
    fi
}

WORKTREE_BASE=$(canonical_path_maybe "$WORKTREE_BASE")

path_under_base() {
    local path="$1"
    [[ "$path" == "${WORKTREE_BASE}/"* ]]
}

ensure_managed_path() {
    local path="$1"
    if ! path_under_base "$path"; then
        error "Refusing unmanaged path: $path"
        echo "Expected path under ${WORKTREE_BASE}/" >&2
        exit 1
    fi
}

validate_slug() {
    local slug="$1"
    if [[ "$slug" == */* ]]; then
        error "Invalid session slug '$slug': slashes are not allowed."
        exit 1
    fi
    if [[ ! "$slug" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
        error "Invalid session slug '$slug': use letters, numbers, '.', '_' or '-'."
        exit 1
    fi
}

sql_escape() {
    printf '%s' "$1" | sed "s/'/''/g"
}

short_hash() {
    local text="$1"
    printf '%s' "$text" | shasum | awk '{print substr($1, 1, 6)}'
}

acquire_lock() {
    local key="$1"
    local lock_root="${XDG_CACHE_HOME:-$HOME/.cache}/ws/locks"
    mkdir -p "$lock_root"
    LOCK_PATH="${lock_root}/${key}.lock"
    if ! mkdir "$LOCK_PATH" 2>/dev/null; then
        error "Another ws operation is already running for this target."
        exit 1
    fi
    trap cleanup_lock EXIT
}

detect_repo_info() {
    local url
    url=$(git config --get remote.origin.url 2>/dev/null) || {
        error "Not in a git repository or no 'origin' remote"
        exit 1
    }
    url="${url%.git}"

    if [[ "$url" =~ ^git@[^:]+:([^/]+)/([^/]+)$ ]]; then
        REPO_ORG="${BASH_REMATCH[1]}"
        REPO_NAME="${BASH_REMATCH[2]}"
    elif [[ "$url" =~ ^https://[^/]+/([^/]+)/([^/]+)$ ]]; then
        REPO_ORG="${BASH_REMATCH[1]}"
        REPO_NAME="${BASH_REMATCH[2]}"
    elif [[ "$url" =~ ^ssh://git@[^/]+/([^/]+)/([^/]+)$ ]]; then
        REPO_ORG="${BASH_REMATCH[1]}"
        REPO_NAME="${BASH_REMATCH[2]}"
    else
        error "Cannot parse origin URL: $url"
        exit 1
    fi

    REPO_DIR=$(git rev-parse --show-toplevel)
    REPO_DIR=$(canonical_dir "$REPO_DIR")
    REPO_WT_DIR="${WORKTREE_BASE}/${REPO_NAME}"
}

set_repo_from_owner_repo() {
    local owner="$1"
    local repo="$2"
    local repo_dir="$HOME/Development/${owner}/${repo}"

    if [[ ! -d "${repo_dir}/.git" ]]; then
        error "Local clone not found at ${repo_dir}"
        echo "Clone it first: gh repo clone ${owner}/${repo} ${repo_dir}" >&2
        exit 1
    fi

    REPO_ORG="$owner"
    REPO_NAME="$repo"
    REPO_DIR=$(canonical_dir "$repo_dir")
    REPO_WT_DIR="${WORKTREE_BASE}/${REPO_NAME}"
}

get_default_branch() {
    git -C "$REPO_DIR" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
        | sed 's@^refs/remotes/origin/@@' || echo "main"
}

prune_stale_origin_refs() {
    local repo_dir="$1"
    local tmp_dir local_refs remote_refs stale_refs count ref
    tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/ws-stale-refs.XXXXXX")
    local_refs="$tmp_dir/local"
    remote_refs="$tmp_dir/remote"
    stale_refs="$tmp_dir/stale"

    git -C "$repo_dir" for-each-ref --format='%(refname)' refs/remotes/origin \
        | grep -v '^refs/remotes/origin/HEAD$' \
        | sort > "$local_refs"
    git -C "$repo_dir" ls-remote --heads origin \
        | awk '{sub("refs/heads/", "refs/remotes/origin/", $2); print $2}' \
        | sort > "$remote_refs"
    comm -23 "$local_refs" "$remote_refs" > "$stale_refs"

    count=$(wc -l < "$stale_refs" | tr -d ' ')
    if [[ "$count" -gt 0 ]]; then
        log "Pruning ${count} stale origin remote-tracking ref(s)..."
        while IFS= read -r ref; do
            [[ -n "$ref" ]] || continue
            git -C "$repo_dir" update-ref -d "$ref"
        done < "$stale_refs"
    fi

    rm -rf "$tmp_dir"
}

fetch_origin_quiet() {
    local repo_dir="$1"
    shift
    local err_file
    err_file=$(mktemp "${TMPDIR:-/tmp}/ws-fetch.XXXXXX")

    if git -C "$repo_dir" fetch --quiet origin "$@" 2>"$err_file"; then
        rm -f "$err_file"
        return 0
    fi

    if grep -q "could not delete references: cannot lock ref 'refs/remotes/origin/" "$err_file"; then
        cat "$err_file" >&2
        log "Fetch failed while pruning stale origin refs; cleaning stale refs and retrying..."
        rm -f "$err_file"
        prune_stale_origin_refs "$repo_dir"
        git -C "$repo_dir" fetch --quiet origin "$@"
        return
    fi

    cat "$err_file" >&2
    rm -f "$err_file"
    return 1
}

branch_exists() {
    local repo_dir="$1"
    local branch="$2"
    git -C "$repo_dir" show-ref --verify --quiet "refs/heads/${branch}"
}

worktree_registered_in_repo() {
    local repo_root="$1"
    local wt_path="$2"
    git -C "$repo_root" worktree list --porcelain 2>/dev/null \
        | sed -n 's/^worktree //p' \
        | grep -Fxq "$wt_path"
}

worktree_path_for_named() {
    local name="$1"
    echo "${REPO_WT_DIR}/${WS_USER}/${name}"
}

worktree_path_for_pr() {
    local pr_number="$1"
    echo "${REPO_WT_DIR}/pr-${pr_number}"
}

managed_worktree_paths() {
    local gitfile
    shopt -s nullglob
    for gitfile in \
        "$WORKTREE_BASE"/*/*/.git \
        "$WORKTREE_BASE"/*/*/*/.git \
        "$WORKTREE_BASE"/*/*/*/*/.git; do
        [[ -f "$gitfile" ]] && dirname "$gitfile"
    done | sort
}

repo_name_from_worktree_path() {
    local wt_path="$1"
    local rel="${wt_path#${WORKTREE_BASE}/}"
    echo "${rel%%/*}"
}

worktree_display_name() {
    local wt_path="$1"
    local repo="$2"
    local prefix="${WORKTREE_BASE}/${repo}/"
    if [[ "$wt_path" == "$prefix"* ]]; then
        echo "${wt_path#$prefix}"
    else
        basename "$wt_path"
    fi
}

latest_copilot_session_for_path() {
    local wt_path="$1"
    [[ -f "$COPILOT_DB" ]] || return 1
    command -v sqlite3 >/dev/null 2>&1 || return 1

    local escaped
    escaped=$(sql_escape "$wt_path")

    local query
    query=$(cat <<SQL
SELECT COALESCE(
  (
    SELECT wss.active_session_id
    FROM workspace_checkout_bindings wcb
    JOIN workspace_session_state wss ON wss.workspace_id = wcb.workspace_id
    WHERE wcb.checkout_path = '${escaped}'
      AND wss.active_session_id IS NOT NULL
      AND wss.active_session_id != ''
    LIMIT 1
  ),
  (
    WITH ranked AS (
      SELECT
        swm.session_id,
        ROW_NUMBER() OVER (ORDER BY s.updated_at DESC) AS rn
      FROM workspace_checkout_bindings wcb
      JOIN session_workspace_map swm ON swm.workspace_id = wcb.workspace_id
      JOIN sessions s ON s.id = swm.session_id
      WHERE wcb.checkout_path = '${escaped}'
    )
    SELECT session_id FROM ranked WHERE rn = 1
  )
);
SQL
)

    sqlite3 -noheader "$COPILOT_DB" "$query" 2>/dev/null | head -n1 | tr -d '[:space:]'
}

latest_copilot_session_title_for_id() {
    local session_id="$1"
    [[ -f "$COPILOT_DB" ]] || return 1
    [[ -n "$session_id" ]] || return 1
    command -v sqlite3 >/dev/null 2>&1 || return 1

    local escaped
    escaped=$(sql_escape "$session_id")
    sqlite3 -noheader "$COPILOT_DB" \
        "SELECT COALESCE(NULLIF(title, ''), '') FROM sessions WHERE id='${escaped}' LIMIT 1;" \
        2>/dev/null | head -n1
}

latest_copilot_session_updated_at_for_id() {
    local session_id="$1"
    [[ -f "$COPILOT_DB" ]] || return 1
    [[ -n "$session_id" ]] || return 1
    command -v sqlite3 >/dev/null 2>&1 || return 1

    local escaped
    escaped=$(sql_escape "$session_id")
    sqlite3 -noheader "$COPILOT_DB" \
        "SELECT COALESCE(NULLIF(updated_at, ''), '') FROM sessions WHERE id='${escaped}' LIMIT 1;" \
        2>/dev/null | head -n1
}

format_updated_at() {
    local iso="$1"
    [[ -n "$iso" ]] || {
        printf '%s' "-"
        return 0
    }
    if command -v python3 >/dev/null 2>&1; then
        python3 - "$iso" <<'PY'
from datetime import datetime, timezone
import sys

iso = sys.argv[1]
try:
    ts = datetime.fromisoformat(iso.replace("Z", "+00:00"))
    now = datetime.now(timezone.utc)
    seconds = max(0, int((now - ts).total_seconds()))
    if seconds < 60:
        print("now")
    elif seconds < 3600:
        print(f"{(seconds + 59) // 60}m")
    elif seconds < 86400:
        print(f"{(seconds + 3599) // 3600}h")
    elif seconds < 604800:
        print(f"{(seconds + 86399) // 86400}d")
    else:
        print(f"{(seconds + 604799) // 604800}w")
except Exception:
    print(iso)
PY
        return 0
    fi
    printf '%s' "$iso"
}

normalize_cell() {
    local value="$1"
    value="${value//$'\t'/ }"
    value="${value//$'\n'/ }"
    value="${value//$'\r'/ }"
    printf '%s' "$value"
}

render_table() {
    if command -v column >/dev/null 2>&1; then
        column -t -s $'\t'
    else
        cat
    fi
}

json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

shell_quote() {
    local s="$1"
    s=${s//\'/\'\\\'\'}
    printf "'%s'" "$s"
}

require_command() {
    local command_name="$1"
    command -v "$command_name" >/dev/null 2>&1 || {
        error "$command_name is required"
        exit 1
    }
}

output_list_rows() {
    local output_format="$1"
    local output_view="$2"
    shift 2
    local records=("$@")
    local sep=$'\x1f'
    local sorted_records=()
    local record

    while IFS= read -r record; do
        sorted_records+=("$record")
    done < <(printf '%s\n' "${records[@]}" | LC_ALL=C sort -t "$sep" -k1,1 -k7,7r -k2,2)

    records=("${sorted_records[@]}")

    if [[ "$output_format" == "json" ]]; then
        local first=1
        printf "[\n"
        for record in "${records[@]}"; do
            local repo name path branch copilot_session resume_id last_active_iso last_active
            IFS="$sep" read -r repo name path branch copilot_session resume_id last_active_iso last_active <<<"$record"
            [[ "$first" -eq 1 ]] || printf ",\n"
            first=0

            if [[ "$output_view" == "simple" ]]; then
                printf '  {"repo":"%s","name":"%s","branch":"%s","lastActive":"%s","lastActiveHuman":"%s"}' \
                    "$(json_escape "$repo")" \
                    "$(json_escape "$name")" \
                    "$(json_escape "$branch")" \
                    "$(json_escape "$last_active_iso")" \
                    "$(json_escape "$last_active")"
            else
                printf '  {"repo":"%s","name":"%s","path":"%s","branch":"%s","lastActive":"%s","lastActiveHuman":"%s","copilotSession":"%s","resumeId":"%s"}' \
                    "$(json_escape "$repo")" \
                    "$(json_escape "$name")" \
                    "$(json_escape "$path")" \
                    "$(json_escape "$branch")" \
                    "$(json_escape "$last_active_iso")" \
                    "$(json_escape "$last_active")" \
                    "$(json_escape "$copilot_session")" \
                    "$(json_escape "$resume_id")"
            fi
        done
        printf "\n]\n"
        return 0
    fi

    {
        if [[ "$output_view" == "simple" ]]; then
            printf "REPO\tNAME\tBRANCH\tLAST_ACTIVE\n"
        else
            printf "REPO\tNAME\tPATH\tBRANCH\tLAST_ACTIVE\tCOPILOT_SESSION\tRESUME_ID\n"
        fi
        local record
        for record in "${records[@]}"; do
            local repo name path branch copilot_session resume_id last_active_iso last_active
            IFS="$sep" read -r repo name path branch copilot_session resume_id last_active_iso last_active <<<"$record"
            if [[ "$output_view" == "simple" ]]; then
                printf "%s\t%s\t%s\t%s\n" "$repo" "$name" "$branch" "$last_active"
            else
                printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
                    "$repo" "$name" "$path" "$branch" "$last_active" "$copilot_session" "$resume_id"
            fi
        done
    } | render_table
}

worktree_title_from_path() {
    local wt_path="$1"
    local repo display session
    repo=$(repo_name_from_worktree_path "$wt_path")
    display=$(worktree_display_name "$wt_path" "$repo")
    printf '%s:%s' "$repo" "$display"
}

set_terminal_title() {
    local title="$1"
    printf '\033]0;%s\007' "$title"
}

open_worktree() {
    local wt_path="$1"
    wt_path=$(canonical_dir "$wt_path")

    ensure_managed_path "$wt_path"

    case "$WS_OPEN_MODE" in
        print|path|none)
            printf '%s\n' "$wt_path"
            ;;
        ghostty)
            local title
            title=$(worktree_title_from_path "$wt_path")
            if [[ "$(uname -s)" == "Darwin" ]] && command -v open >/dev/null 2>&1; then
                log "Opening Ghostty: $title"
                open -na "Ghostty" --args "--working-directory=${wt_path}" "--title=${title}"
            else
                printf '%s\n' "$wt_path"
            fi
            ;;
        *)
            error "Invalid WS_OPEN_MODE '$WS_OPEN_MODE' (expected: ghostty|print)"
            exit 1
            ;;
    esac
}

parse_pr_ref() {
    local ref="$1"

    if [[ "$ref" =~ github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]]; then
        PR_ORG="${BASH_REMATCH[1]}"
        PR_REPO="${BASH_REMATCH[2]}"
        PR_NUMBER="${BASH_REMATCH[3]}"
    elif [[ "$ref" =~ ^[0-9]+$ ]]; then
        detect_repo_info
        PR_ORG="$REPO_ORG"
        PR_REPO="$REPO_NAME"
        PR_NUMBER="$ref"
    else
        error "Invalid PR reference: $ref"
        echo "Use a PR number (in a repo) or URL: https://github.com/owner/repo/pull/123" >&2
        exit 1
    fi
}

resolve_worktree_globally() {
    local input="$1"
    local candidate=""

    candidate="${WORKTREE_BASE}/${input}"
    [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }

    [[ -d "$WORKTREE_BASE" ]] || return 1

    local matches=()
    while IFS= read -r wt; do
        matches+=("$wt")
    done < <(
        managed_worktree_paths \
            | while IFS= read -r wt_path; do
                local rel repo display
                rel="${wt_path#${WORKTREE_BASE}/}"
                repo="${rel%%/*}"
                display="${rel#*/}"
                if [[ "$rel" == "$input" || "$display" == "$input" || "$(basename "$wt_path")" == "$input" ]]; then
                    echo "$wt_path"
                fi
            done | sort
    )

    if [[ ${#matches[@]} -eq 1 ]]; then
        canonical_dir "${matches[0]}"
        return 0
    fi

    if [[ ${#matches[@]} -gt 1 ]]; then
        error "Ambiguous worktree '$input'. Use full path or repo-relative path."
        printf '  %s\n' "${matches[@]}" >&2
        exit 1
    fi

    return 1
}

resolve_worktree_for_open() {
    local input="$1"

    if [[ -d "$input" ]]; then
        canonical_dir "$input"
        return 0
    fi

    if git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
        && git config --get remote.origin.url >/dev/null 2>&1; then
        detect_repo_info

        local candidate=""
        if [[ "$input" =~ ^pr-[0-9]+$ ]]; then
            candidate="${REPO_WT_DIR}/${input}"
            [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }
        fi

        candidate="$(worktree_path_for_named "$input")"
        [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }

        candidate="${REPO_WT_DIR}/${input}"
        [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }

        local matches=()
        while IFS= read -r d; do
            matches+=("$d")
        done < <(find "$REPO_WT_DIR" -mindepth 1 -maxdepth 4 -type d -name "$input" 2>/dev/null | sort)

        if [[ ${#matches[@]} -eq 1 ]]; then
            canonical_dir "${matches[0]}"
            return 0
        fi

        if [[ ${#matches[@]} -gt 1 ]]; then
            error "Ambiguous worktree name '$input'."
            printf '  %s\n' "${matches[@]}" >&2
            exit 1
        fi
    fi

    if resolve_worktree_globally "$input"; then
        return 0
    fi

    error "Worktree '$input' not found under ${WORKTREE_BASE}/"
    exit 1
}

resolve_worktree_for_delete() {
    local input="$1"

    if [[ -d "$input" ]]; then
        canonical_dir "$input"
        return 0
    fi

    local candidate=""
    candidate="${WORKTREE_BASE}/${input}"
    [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }

    if git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
        && git config --get remote.origin.url >/dev/null 2>&1; then
        detect_repo_info
        if [[ "$input" =~ ^pr-[0-9]+$ ]]; then
            candidate="${REPO_WT_DIR}/${input}"
            [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }
        fi

        candidate="$(worktree_path_for_named "$input")"
        [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }

        candidate="${REPO_WT_DIR}/${input}"
        [[ -d "$candidate" ]] && { canonical_dir "$candidate"; return 0; }
    fi

    local matches=()
    while IFS= read -r wt; do
        matches+=("$wt")
    done < <(
        managed_worktree_paths \
            | while IFS= read -r wt_path; do
                rel=""
                rel="${wt_path#${WORKTREE_BASE}/}"
                if [[ "$rel" == "$input" || "$(basename "$wt_path")" == "$input" ]]; then
                    echo "$wt_path"
                fi
            done | sort
    )

    if [[ ${#matches[@]} -eq 1 ]]; then
        canonical_dir "${matches[0]}"
        return 0
    fi
    if [[ ${#matches[@]} -gt 1 ]]; then
        error "Ambiguous worktree '$input'. Use full path or repo-relative path."
        printf '  %s\n' "${matches[@]}" >&2
        exit 1
    fi

    error "Worktree '$input' not found under ${WORKTREE_BASE}/"
    exit 1
}

codespace_list_json() {
    require_command gh
    gh cs list --limit 100 --json name,displayName,repository,state,lastUsedAt
}

codespace_jq_repo_expr='
def repo_name:
  .repository
  | if type == "object" then (.nameWithOwner // .fullName // .name // "")
    else (. // "")
    end;
'

codespace_lookup() {
    local query="$1"
    require_command jq
    codespace_list_json \
        | jq -r --arg query "$query" "${codespace_jq_repo_expr}
            .[]
            | select(.name == \$query or .displayName == \$query)
            | [.name, (.displayName // \"\"), repo_name, (.state // \"\"), (.lastUsedAt // \"\")]
            | @tsv" \
        | head -n1
}

codespace_saved_name() {
    if [[ -n "${WS_BLESSED_CODESPACE:-}" ]]; then
        printf '%s\n' "$WS_BLESSED_CODESPACE"
        return 0
    fi

    [[ -f "$WS_BLESSED_CODESPACE_STATE" ]] || return 1
    require_command jq
    jq -r '.name // empty' "$WS_BLESSED_CODESPACE_STATE"
}

codespace_write_state() {
    local name="$1"
    local display_name="$2"
    local repo="$3"
    local state="$4"
    local last_used="$5"

    mkdir -p "$WS_STATE_DIR"
    cat > "$WS_BLESSED_CODESPACE_STATE" <<JSON
{
  "name": "$(json_escape "$name")",
  "displayName": "$(json_escape "$display_name")",
  "repository": "$(json_escape "$repo")",
  "state": "$(json_escape "$state")",
  "lastUsedAt": "$(json_escape "$last_used")",
  "remoteRoot": "$(json_escape "$WS_CODESPACE_REMOTE_ROOT")"
}
JSON
}

codespace_select() {
    require_command jq

    if command -v fzf >/dev/null 2>&1; then
        local selection
        selection=$(
            codespace_list_json \
                | jq -r "${codespace_jq_repo_expr}
                    .[]
                    | [.name, (.displayName // \"\"), repo_name, (.state // \"\"), (.lastUsedAt // \"\")]
                    | @tsv" \
                | awk -F'\t' '{
                    printf "%-34s  %-22s  %-28s  %-10s\t%s\n", $1, $2, $3, $4, $1
                }' \
                | fzf --reverse \
                      --prompt 'codespace> ' \
                      --delimiter $'\t' \
                      --with-nth=1 \
                      --preview 'printf "%s\n" {} | cut -f2' \
                      --preview-window 'down,3,wrap'
        )
        [[ -n "$selection" ]] || exit 0
        printf '%s\n' "$selection" | cut -f2
        return 0
    fi

    local names=()
    local line index=1
    while IFS= read -r line; do
        names+=("$(printf '%s' "$line" | cut -f1)")
        printf '%2d) %s\n' "$index" "$line" >&2
        index=$((index + 1))
    done < <(
        codespace_list_json \
            | jq -r "${codespace_jq_repo_expr}
                .[]
                | [.name, (.displayName // \"\"), repo_name, (.state // \"\"), (.lastUsedAt // \"\")]
                | @tsv"
    )

    [[ ${#names[@]} -gt 0 ]] || {
        error "No Codespaces found."
        exit 1
    }

    local choice
    read -rp "Codespace number: " choice
    [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#names[@]} )) || {
        error "Invalid Codespace selection."
        exit 1
    }
    printf '%s\n' "${names[$((choice - 1))]}"
}

codespace_resolve() {
    local allow_interactive="${1:-false}"
    local candidate=""

    candidate=$(codespace_saved_name || true)
    if [[ -z "$candidate" && "$allow_interactive" == "true" ]]; then
        candidate=$(codespace_select)
        cmd_cs_bless "$candidate" >/dev/null
    fi

    [[ -n "$candidate" ]] || {
        error "No blessed Codespace configured."
        echo "Run 'ws cs bless [codespace]' first, or set WS_BLESSED_CODESPACE." >&2
        exit 1
    }

    local record
    record=$(codespace_lookup "$candidate")
    [[ -n "$record" ]] || {
        error "Blessed Codespace not found: $candidate"
        echo "Run 'ws cs bless' to choose a current Codespace." >&2
        exit 1
    }

    printf '%s\n' "$record" | cut -f1
}

codespace_remote_path() {
    detect_repo_info

    local key="${REPO_ORG}/${REPO_NAME}"
    if [[ -n "${WS_CODESPACE_REMOTE_PATH:-}" ]]; then
        printf '%s\n' "$WS_CODESPACE_REMOTE_PATH"
        return 0
    fi

    if [[ -f "$WS_CODESPACE_REPO_MAP" ]]; then
        local mapped
        mapped=$(awk -F'\t' -v key="$key" -v repo="$REPO_NAME" '
            $1 == key || $1 == repo { print $2; exit }
        ' "$WS_CODESPACE_REPO_MAP")
        if [[ -n "$mapped" ]]; then
            printf '%s\n' "$mapped"
            return 0
        fi
    fi

    [[ -n "$REPO_NAME" ]] || {
        error "Cannot infer Codespace repo path."
        exit 1
    }
    printf '%s/%s\n' "$WS_CODESPACE_REMOTE_ROOT" "$REPO_NAME"
}

current_branch() {
    local branch
    branch=$(git -C "$REPO_DIR" rev-parse --abbrev-ref HEAD)
    if [[ "$branch" == "HEAD" ]]; then
        error "Cannot sync from detached HEAD."
        exit 1
    fi
    printf '%s\n' "$branch"
}

codespace_remote_command() {
    local codespace="$1"
    shift
    local command="$1"
    shift

    local quoted_args=()
    local arg
    for arg in "$@"; do
        quoted_args+=("$(shell_quote "$arg")")
    done

    gh cs ssh -c "$codespace" "bash -s -- ${quoted_args[*]}" <<<"$command"
}

cmd_cs_bless() {
    local requested="${1:-}"
    local name

    if [[ -n "$requested" ]]; then
        name="$requested"
    else
        name=$(codespace_select)
    fi

    local record
    record=$(codespace_lookup "$name")
    [[ -n "$record" ]] || {
        error "Codespace not found: $name"
        exit 1
    }

    local actual display repo state last_used
    IFS=$'\t' read -r actual display repo state last_used <<<"$record"
    codespace_write_state "$actual" "$display" "$repo" "$state" "$last_used"
    echo "Blessed Codespace: ${actual}"
}

cmd_cs_status() {
    local codespace
    codespace=$(codespace_resolve false)

    detect_repo_info
    local branch head remote_path record display repo state last_used
    branch=$(current_branch)
    head=$(git -C "$REPO_DIR" rev-parse HEAD)
    remote_path=$(codespace_remote_path)
    record=$(codespace_lookup "$codespace")
    IFS=$'\t' read -r codespace display repo state last_used <<<"$record"

    printf "Codespace\t%s\n" "$codespace"
    printf "Display\t%s\n" "${display:-"-"}"
    printf "State\t%s\n" "${state:-"-"}"
    printf "Codespace repo\t%s\n" "${repo:-"-"}"
    printf "Local repo\t%s/%s\n" "$REPO_ORG" "$REPO_NAME"
    printf "Local branch\t%s\n" "$branch"
    printf "Local HEAD\t%s\n" "$head"
    printf "Remote path\t%s\n" "$remote_path"

    local remote_script='
set -euo pipefail
owner="$1"
repo="$2"
branch="$3"
head="$4"
remote_path="$5"

if [[ ! -e "$remote_path" ]]; then
    echo "Remote found	no"
    exit 0
fi

cd "$remote_path"
remote_url=$(git config --get remote.origin.url 2>/dev/null || true)
if [[ "$remote_url" != *"${owner}/${repo}"* ]]; then
    echo "Remote found	yes"
    echo "Remote repo match	no"
    echo "Remote origin	${remote_url:-"-"}"
    exit 0
fi

remote_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
remote_head=$(git rev-parse HEAD 2>/dev/null || echo "?")
if [[ -n "$(git status --porcelain --untracked-files=all 2>/dev/null)" ]]; then
    dirty=yes
else
    dirty=no
fi
if [[ "$remote_head" == "$head" ]]; then
    synced=yes
else
    synced=no
fi

echo "Remote found	yes"
echo "Remote repo match	yes"
echo "Remote branch	$remote_branch"
echo "Remote HEAD	$remote_head"
echo "Remote dirty	$dirty"
echo "Synced	$synced"
'
    if ! codespace_remote_command "$codespace" "$remote_script" "$REPO_ORG" "$REPO_NAME" "$branch" "$head" "$remote_path"; then
        error "Could not query remote Codespace checkout."
        exit 1
    fi
}

cmd_cs_sync() {
    local force_remote=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force-remote)
                force_remote=true
                shift
                ;;
            *)
                error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    local codespace
    codespace=$(codespace_resolve true)

    detect_repo_info
    local branch head remote_path
    branch=$(current_branch)
    head=$(git -C "$REPO_DIR" rev-parse HEAD)
    remote_path=$(codespace_remote_path)

    if [[ -n "$(git -C "$REPO_DIR" status --porcelain --untracked-files=all)" ]]; then
        log "Local worktree has uncommitted changes; syncing committed HEAD only."
    fi

    log "Pushing ${REPO_ORG}/${REPO_NAME} ${branch} (${head:0:12}) to origin..."
    git -C "$REPO_DIR" push origin "HEAD:${branch}"

    local remote_script='
set -euo pipefail
owner="$1"
repo="$2"
branch="$3"
head="$4"
remote_path="$5"
force_remote="$6"

if [[ ! -e "$remote_path" ]]; then
    echo "Remote repo path does not exist: $remote_path" >&2
    exit 1
fi

cd "$remote_path"
remote_url=$(git config --get remote.origin.url 2>/dev/null || true)
if [[ "$remote_url" != *"${owner}/${repo}"* ]]; then
    echo "Remote origin does not match ${owner}/${repo}: ${remote_url:-"(missing)"}" >&2
    exit 1
fi

if [[ -n "$(git status --porcelain --untracked-files=all)" && "$force_remote" != "true" ]]; then
    echo "Remote checkout has local changes: $remote_path" >&2
    echo "Use ws cs sync --force-remote to discard them." >&2
    exit 1
fi
if [[ "$force_remote" == "true" ]]; then
    git reset --hard
    git clean -fd
fi

git fetch origin "$branch"
git cat-file -e "${head}^{commit}"
git checkout -B "$branch" "$head"
git reset --hard "$head"
if [[ "$force_remote" == "true" ]]; then
    git clean -fd
fi

actual=$(git rev-parse HEAD)
if [[ "$actual" != "$head" ]]; then
    echo "Remote sync ended at $actual, expected $head" >&2
    exit 1
fi

echo "Synced ${owner}/${repo} ${branch} to ${head}"
'
    codespace_remote_command "$codespace" "$remote_script" "$REPO_ORG" "$REPO_NAME" "$branch" "$head" "$remote_path" "$force_remote"
}

cmd_cs_ssh() {
    local codespace
    codespace=$(codespace_resolve false)
    gh cs ssh -c "$codespace" "$@"
}

cmd_cs_repo() {
    local codespace remote_path
    codespace=$(codespace_resolve false)
    remote_path=$(codespace_remote_path)
    gh cs ssh -c "$codespace" "cd $(shell_quote "$remote_path") && exec \${SHELL:-bash} -l"
}

cmd_cs_ports() {
    local codespace
    codespace=$(codespace_resolve false)
    gh cs ports -c "$codespace" "$@"
}

cmd_cs_forward() {
    [[ $# -ge 1 ]] || {
        error "Usage: ws cs forward <remote-port>:<local-port>..."
        exit 1
    }
    local codespace
    codespace=$(codespace_resolve false)
    gh cs ports forward "$@" -c "$codespace"
}

codespace_web_port_label() {
    case "$1" in
        80) echo "web" ;;
        2206) echo "Copilot API" ;;
        2208) echo "sweagentd-http" ;;
        2210) echo "copilot-mission-control-http" ;;
        3011) echo "web-alt" ;;
        8091) echo "authzd" ;;
        8088) echo "notifyd" ;;
        *) echo "custom" ;;
    esac
}

codespace_web_ports() {
    local port
    for port in $WS_CODESPACE_WEB_PORTS; do
        [[ "$port" =~ ^[0-9]+$ ]] || {
            error "Invalid port in WS_CODESPACE_WEB_PORTS: $port"
            exit 1
        }
        printf '%s\n' "$port"
    done
}

codespace_state_key() {
    printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'
}

codespace_web_state_dir() {
    printf '%s/web-ports-%s\n' "$WS_STATE_DIR" "$(codespace_state_key "$1")"
}

codespace_web_pid_file() {
    printf '%s/port-%s.pid\n' "$(codespace_web_state_dir "$1")" "$2"
}

codespace_web_log_file() {
    printf '%s/port-%s.log\n' "$(codespace_web_state_dir "$1")" "$2"
}

codespace_web_pid() {
    local file
    file=$(codespace_web_pid_file "$1" "$2")
    [[ -f "$file" ]] || return 1
    sed -n '1p' "$file"
}

codespace_web_pid_is_forwarder() {
    local pid="$1"
    local port="$2"
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    kill -0 "$pid" 2>/dev/null || return 1

    local command_line
    command_line=$(ps -p "$pid" -o command= 2>/dev/null || true)
    [[ "$command_line" == *"gh"* && "$command_line" == *"ports forward"* && "$command_line" == *"${port}:${port}"* ]]
}

codespace_web_port_running() {
    local codespace="$1"
    local port="$2"
    local pid_file pid
    pid_file=$(codespace_web_pid_file "$codespace" "$port")
    pid=$(codespace_web_pid "$codespace" "$port" || true)

    if codespace_web_pid_is_forwarder "$pid" "$port"; then
        return 0
    fi

    [[ -f "$pid_file" ]] && rm -f "$pid_file"
    return 1
}

codespace_web_running() {
    local codespace="$1"
    local port
    while IFS= read -r port; do
        if codespace_web_port_running "$codespace" "$port"; then
            return 0
        fi
    done < <(codespace_web_ports)
    return 1
}

cmd_cs_web_ports_status() {
    local codespace state_dir state="stopped"
    codespace=$(codespace_resolve false)
    state_dir=$(codespace_web_state_dir "$codespace")

    if codespace_web_running "$codespace"; then
        state="running"
    fi

    printf "Codespace\t%s\n" "$codespace"
    printf "Forwarder\t%s\n" "$state"
    printf "State dir\t%s\n" "$state_dir"
    printf "Ports\n"

    local port port_state pid log_file
    while IFS= read -r port; do
        port_state="stopped"
        pid="-"
        log_file=$(codespace_web_log_file "$codespace" "$port")
        if codespace_web_port_running "$codespace" "$port"; then
            port_state="running"
            pid=$(codespace_web_pid "$codespace" "$port")
        fi
        printf "  %s:%s\t%s\t%s\t%s\t%s\n" \
            "$port" "$port" "$(codespace_web_port_label "$port")" "$port_state" "$pid" "$log_file"
    done < <(codespace_web_ports)
}

cmd_cs_web_ports_start() {
    local codespace state_dir
    codespace=$(codespace_resolve false)
    state_dir=$(codespace_web_state_dir "$codespace")

    local ports=()
    local configured_port
    while IFS= read -r configured_port; do
        ports+=("$configured_port")
    done < <(codespace_web_ports)
    [[ ${#ports[@]} -gt 0 ]] || {
        error "No web ports configured."
        exit 1
    }

    mkdir -p "$state_dir"

    local port pid pid_file log_file started=0 failed=0
    for port in "${ports[@]}"; do
        if codespace_web_port_running "$codespace" "$port"; then
            echo "Port ${port} already forwarding for ${codespace} (PID $(codespace_web_pid "$codespace" "$port"))."
            continue
        fi

        pid_file=$(codespace_web_pid_file "$codespace" "$port")
        log_file=$(codespace_web_log_file "$codespace" "$port")
        log "Starting web port forwarding for ${codespace}: ${port}:${port} ($(codespace_web_port_label "$port"))"
        nohup gh cs ports forward "${port}:${port}" -c "$codespace" >"$log_file" 2>&1 &
        pid=$!
        printf '%s\n' "$pid" > "$pid_file"
        started=$((started + 1))
    done

    sleep 2

    for port in "${ports[@]}"; do
        if ! codespace_web_port_running "$codespace" "$port"; then
            failed=$((failed + 1))
            log_file=$(codespace_web_log_file "$codespace" "$port")
            error "Port ${port} forwarder exited. Log:"
            tail -n 20 "$log_file" >&2 2>/dev/null || true
        fi
    done

    if [[ "$failed" -gt 0 ]]; then
        error "${failed} web port forwarder(s) failed."
        exit 1
    fi

    echo "Started ${started} web port forwarder(s) for ${codespace}."
    echo "State: ${state_dir}"
}

cmd_cs_web_ports_stop() {
    local codespace stopped=0
    codespace=$(codespace_resolve false)

    local port pid pid_file
    while IFS= read -r port; do
        if ! codespace_web_port_running "$codespace" "$port"; then
            continue
        fi

        pid=$(codespace_web_pid "$codespace" "$port")
        pid_file=$(codespace_web_pid_file "$codespace" "$port")
        kill "$pid"
        sleep 1
        if kill -0 "$pid" 2>/dev/null; then
            error "Forwarder did not stop yet: port ${port}, PID ${pid}"
            exit 1
        fi
        rm -f "$pid_file"
        stopped=$((stopped + 1))
        echo "Stopped ${port}:${port} for ${codespace}."
    done < <(codespace_web_ports)

    if [[ "$stopped" -eq 0 ]]; then
        echo "Web port forwarding is not running for ${codespace}."
    fi
}

cmd_cs_web_ports() {
    local action="${1:-toggle}"
    case "$action" in
        toggle)
            local codespace
            codespace=$(codespace_resolve false)
            if codespace_web_running "$codespace"; then
                cmd_cs_web_ports_stop
            else
                cmd_cs_web_ports_start
            fi
            ;;
        start) cmd_cs_web_ports_start ;;
        stop) cmd_cs_web_ports_stop ;;
        status|--status) cmd_cs_web_ports_status ;;
        *)
            error "Usage: ws cs web-ports [toggle|start|stop|status|--status]"
            exit 1
            ;;
    esac
}

cmd_cs() {
    local subcommand="${1:-}"
    [[ -n "$subcommand" ]] || {
        show_cs_help
        exit 0
    }
    shift

    case "$subcommand" in
        -h|--help|help) show_cs_help ;;
        bless) cmd_cs_bless "$@" ;;
        status) cmd_cs_status "$@" ;;
        sync) cmd_cs_sync "$@" ;;
        ssh) cmd_cs_ssh "$@" ;;
        repo) cmd_cs_repo "$@" ;;
        ports) cmd_cs_ports "$@" ;;
        forward) cmd_cs_forward "$@" ;;
        web-ports|web) cmd_cs_web_ports "$@" ;;
        *)
            error "Unknown ws cs command '$subcommand'"
            exit 1
            ;;
    esac
}

cmd_new() {
    local name=""
    local pr_ref=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --pr)
                [[ $# -ge 2 ]] || { error "--pr requires a value"; exit 1; }
                pr_ref="$2"
                shift 2
                ;;
            -*)
                error "Unknown option: $1"
                exit 1
                ;;
            *)
                name="$1"
                shift
                ;;
        esac
    done

    if [[ -n "$pr_ref" ]]; then
        parse_pr_ref "$pr_ref"
        set_repo_from_owner_repo "$PR_ORG" "$PR_REPO"

        local wt_path
        wt_path=$(worktree_path_for_pr "$PR_NUMBER")
        ensure_managed_path "$wt_path"

        if [[ -d "$wt_path" ]]; then
            log "Worktree already exists: $wt_path"
            open_worktree "$wt_path"
            return 0
        fi

        mkdir -p "$(dirname "$wt_path")"
        acquire_lock "$(short_hash "$wt_path")"

        log "Fetching PR #${PR_NUMBER} for ${PR_ORG}/${PR_REPO}..."
        fetch_origin_quiet "$REPO_DIR" "pull/${PR_NUMBER}/head:refs/remotes/origin/pr/${PR_NUMBER}"

        local pr_branch="pr-${PR_NUMBER}"
        if branch_exists "$REPO_DIR" "$pr_branch"; then
            log "Local branch '${pr_branch}' already exists; reusing it."
            git -C "$REPO_DIR" worktree add --quiet "$wt_path" "$pr_branch"
        else
            log "Creating worktree: $wt_path"
            git -C "$REPO_DIR" worktree add --quiet -b "$pr_branch" "$wt_path" "refs/remotes/origin/pr/${PR_NUMBER}"
        fi

        open_worktree "$wt_path"
        return 0
    fi

    [[ -n "$name" ]] || {
        error "Usage: ws new <session-slug>  or  ws new --pr <n|url>"
        exit 1
    }
    validate_slug "$name"

    detect_repo_info

    local wt_path
    wt_path=$(worktree_path_for_named "$name")
    ensure_managed_path "$wt_path"

    if [[ -d "$wt_path" ]]; then
        log "Worktree already exists: $wt_path"
        open_worktree "$wt_path"
        return 0
    fi

    mkdir -p "$(dirname "$wt_path")"
    acquire_lock "$(short_hash "$wt_path")"

    local default_branch branch
    default_branch=$(get_default_branch)
    branch="${WS_USER}/${name}"

    log "Fetching latest from origin..."
    fetch_origin_quiet "$REPO_DIR"

    if branch_exists "$REPO_DIR" "$branch"; then
        log "Local branch '${branch}' already exists; reusing it."
        git -C "$REPO_DIR" worktree add --quiet "$wt_path" "$branch"
    else
        log "Creating branch '${branch}' from origin/${default_branch}..."
        git -C "$REPO_DIR" worktree add --quiet -b "$branch" "$wt_path" "origin/${default_branch}"
    fi

    open_worktree "$wt_path"
}

cmd_pr() {
    [[ $# -ge 1 ]] || {
        error "Usage: ws pr <number|url>"
        exit 1
    }
    cmd_new --pr "$1"
}

cmd_open() {
    local target=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --print|--path|--no-open) shift ;;
            -*)
                error "Unknown option: $1"
                exit 1
                ;;
            *)
                target="$1"
                shift
                ;;
        esac
    done

    [[ -n "$target" ]] || {
        error "Usage: ws open [--print] <name|path>"
        exit 1
    }

    local wt_path
    wt_path=$(resolve_worktree_for_open "$target")

    if ! path_under_base "$wt_path"; then
        error "Refusing to open unmanaged path: $wt_path"
        echo "Expected path under ${WORKTREE_BASE}/" >&2
        exit 1
    fi

    printf '%s\n' "$wt_path"
}

cmd_path() {
    [[ $# -ge 1 ]] || {
        error "Usage: ws path <name|path>"
        exit 1
    }

    local wt_path
    wt_path=$(resolve_worktree_for_open "$1")
    ensure_managed_path "$wt_path"
    printf '%s\n' "$wt_path"
}

cmd_title() {
    local wt_path="${1:-$(pwd)}"
    if [[ -d "$wt_path" ]]; then
        wt_path=$(canonical_dir "$wt_path")
    else
        wt_path=$(resolve_worktree_for_open "$wt_path")
    fi
    ensure_managed_path "$wt_path"
    set_terminal_title "$(worktree_title_from_path "$wt_path")"
}

cmd_pick() {
    command -v jq >/dev/null 2>&1 || { error "jq is required for ws pick"; exit 1; }
    command -v fzf >/dev/null 2>&1 || { error "fzf is required for ws pick"; exit 1; }

    local selection path
    selection=$(
        cmd_list_all json full \
            | jq -r '.[] | [.repo, .name, .branch, (.lastActiveHuman // "-"), .path] | @tsv' \
            | awk -F'\t' '
                function fit(s, w) {
                    if (length(s) <= w) return s
                    return substr(s, 1, w - 3) "..."
                }
                {
                    printf "%-12s  %-28s  %-38s  %-11s\t%s\n",
                        fit($1, 12),
                        fit($2, 28),
                        fit($3, 38),
                        fit($4, 11),
                        $5
                }
            ' \
            | fzf --reverse \
                  --prompt 'worktree> ' \
                  --delimiter $'\t' \
                  --with-nth=1 \
                  --preview 'printf "%s\n" {} | cut -f2' \
                  --preview-window 'down,3,wrap'
    )

    [[ -n "$selection" ]] || exit 0
    path=$(printf '%s' "$selection" | cut -f2)
    [[ -n "$path" ]] || exit 1
    open_worktree "$path"
}

cmd_list() {
    local show_all=false
    local output_format="text"
    local output_view="simple"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) show_all=true; shift ;;
            --simple) output_view="simple"; shift ;;
            --full) output_view="full"; shift ;;
            --json) output_format="json"; shift ;;
            --format)
                [[ $# -ge 2 ]] || { error "--format requires a value: text|json"; exit 1; }
                output_format="$2"
                shift 2
                ;;
            *) error "Unknown option: $1"; exit 1 ;;
        esac
    done
    case "$output_format" in
        text|json) ;;
        *) error "Invalid --format value '$output_format' (expected: text|json)"; exit 1 ;;
    esac

    if $show_all; then
        cmd_list_all "$output_format" "$output_view"
        return
    fi

    detect_repo_info
    [[ -d "$REPO_WT_DIR" ]] || {
        echo "No managed worktrees for ${REPO_NAME}."
        return 0
    }

    local rows=()
    local sep=$'\x1f'
    while IFS= read -r line; do
        local wt_path
        wt_path=$(echo "$line" | awk '{print $1}')
        [[ "$wt_path" == "$REPO_DIR" ]] && continue
        [[ "$wt_path" != "${REPO_WT_DIR}/"* ]] && continue

        local display branch resume_id="-" resume_title="-" resume_updated_at="" last_active="-"
        display="${wt_path#${REPO_WT_DIR}/}"
        branch=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
        if [[ "$output_view" == "full" ]]; then
            resume_id=$(latest_copilot_session_for_path "$wt_path" || true)
            resume_title=$(latest_copilot_session_title_for_id "$resume_id" || true)
            resume_updated_at=$(latest_copilot_session_updated_at_for_id "$resume_id" || true)
            last_active=$(format_updated_at "$resume_updated_at")
            [[ -z "$resume_title" ]] && resume_title="-"
            [[ -n "$resume_id" ]] && resume_id="${resume_id:0:12}"
            [[ -z "$resume_id" ]] && resume_id="-"
        fi

        rows+=("$(printf '%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s' \
            "$(normalize_cell "$REPO_NAME")" "$sep" \
            "$(normalize_cell "$display")" "$sep" \
            "$(normalize_cell "$wt_path")" "$sep" \
            "$(normalize_cell "$branch")" "$sep" \
            "$(normalize_cell "$resume_title")" "$sep" \
            "$resume_id" "$sep" \
            "$(normalize_cell "$resume_updated_at")" "$sep" \
            "$(normalize_cell "$last_active")")")
    done < <(git -C "$REPO_DIR" worktree list 2>/dev/null || true)

    if [[ ${#rows[@]} -eq 0 ]]; then
        echo "No managed worktrees for ${REPO_NAME}."
        return 0
    fi

    output_list_rows "$output_format" "$output_view" "${rows[@]}"
}

cmd_list_all() {
    local output_format="${1:-text}"
    local output_view="${2:-simple}"
    [[ -d "$WORKTREE_BASE" ]] || {
        echo "No managed worktrees."
        return 0
    }

    local rows=()
    local sep=$'\x1f'
    while IFS= read -r wt_path; do
        local repo display branch resume_id="-" resume_title="-" resume_updated_at="" last_active="-"
        repo=$(repo_name_from_worktree_path "$wt_path")
        display=$(worktree_display_name "$wt_path" "$repo")
        branch=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
        if [[ "$output_view" == "full" ]]; then
            resume_id=$(latest_copilot_session_for_path "$wt_path" || true)
            resume_title=$(latest_copilot_session_title_for_id "$resume_id" || true)
            resume_updated_at=$(latest_copilot_session_updated_at_for_id "$resume_id" || true)
            last_active=$(format_updated_at "$resume_updated_at")
            [[ -z "$resume_title" ]] && resume_title="-"
            [[ -n "$resume_id" ]] && resume_id="${resume_id:0:12}"
            [[ -z "$resume_id" ]] && resume_id="-"
        fi

        rows+=("$(printf '%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s' \
            "$(normalize_cell "$repo")" "$sep" \
            "$(normalize_cell "$display")" "$sep" \
            "$(normalize_cell "$wt_path")" "$sep" \
            "$(normalize_cell "$branch")" "$sep" \
            "$(normalize_cell "$resume_title")" "$sep" \
            "$resume_id" "$sep" \
            "$(normalize_cell "$resume_updated_at")" "$sep" \
            "$(normalize_cell "$last_active")")")
    done < <(managed_worktree_paths)

    if [[ ${#rows[@]} -eq 0 ]]; then
        echo "No managed worktrees."
        return 0
    fi

    output_list_rows "$output_format" "$output_view" "${rows[@]}"
}

delete_worktree() {
    local wt_path="$1"
    local force="$2"
    if ! path_under_base "$wt_path"; then
        error "Refusing to remove path outside managed root: $wt_path"
        exit 1
    fi
    if [[ ! -f "$wt_path/.git" ]]; then
        error "Not a managed git worktree: $wt_path"
        exit 1
    fi

    local repo display
    repo=$(repo_name_from_worktree_path "$wt_path")
    display=$(worktree_display_name "$wt_path" "$repo")

    acquire_lock "$(short_hash "$wt_path")"

    local common_git_dir repo_root
    common_git_dir=$(git -C "$wt_path" rev-parse --path-format=absolute --git-common-dir)
    repo_root=$(dirname "$common_git_dir")
    if ! worktree_registered_in_repo "$repo_root" "$wt_path"; then
        error "Worktree is not registered in repository metadata: $wt_path"
        exit 1
    fi

    log "Removing worktree: $wt_path"
    if [[ "$force" == "true" ]]; then
        git -C "$repo_root" worktree remove "$wt_path" --force
    else
        git -C "$repo_root" worktree remove "$wt_path"
    fi
    git -C "$repo_root" worktree prune
    cleanup_lock
    LOCK_PATH=""

    local parent
    parent=$(dirname "$wt_path")
    while [[ "$parent" == "${WORKTREE_BASE}/${repo}"* ]]; do
        rmdir "$parent" 2>/dev/null || break
        parent=$(dirname "$parent")
    done

    echo "✓ Deleted worktree: ${repo}/$(worktree_display_name "$wt_path" "$repo")"
}

cmd_delete() {
    local force=false
    local yes=false
    local inputs=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force)
                force=true
                shift
                ;;
            -y|--yes)
                yes=true
                shift
                ;;
            -*)
                error "Unknown option: $1"
                exit 1
                ;;
            *)
                inputs+=("$1")
                shift
                ;;
        esac
    done

    [[ ${#inputs[@]} -ge 1 ]] || {
        error "Usage: ws delete [--force] [--yes] <name|path>..."
        exit 1
    }

    local paths=()
    local input wt_path
    for input in "${inputs[@]}"; do
        wt_path=$(resolve_worktree_for_delete "$input")
        ensure_managed_path "$wt_path"
        paths+=("$wt_path")
    done

    if [[ "$force" != "true" ]]; then
        for wt_path in "${paths[@]}"; do
            if [[ -n "$(git -C "$wt_path" status --porcelain --untracked-files=all 2>/dev/null)" ]]; then
                error "Worktree has local changes: $wt_path"
                echo "Use 'ws delete --force ...' to remove it anyway." >&2
                exit 1
            fi
        done
    fi

    if [[ ${#paths[@]} -gt 1 && "$yes" != "true" ]]; then
        echo "Will delete ${#paths[@]} worktree(s):"
        printf '  %s\n' "${paths[@]}"
        echo
        read -rp "Continue? [y/N] " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; return 0; }
    fi

    for wt_path in "${paths[@]}"; do
        delete_worktree "$wt_path" "$force"
    done
}

cmd_clean() {
    detect_repo_info

    local paths=()
    while IFS= read -r line; do
        local wt_path
        wt_path=$(echo "$line" | awk '{print $1}')
        [[ "$wt_path" == "$REPO_DIR" ]] && continue
        [[ "$wt_path" != "${REPO_WT_DIR}/"* ]] && continue
        paths+=("$wt_path")
    done < <(git -C "$REPO_DIR" worktree list 2>/dev/null || true)

    if [[ ${#paths[@]} -eq 0 ]]; then
        echo "No managed worktrees for ${REPO_NAME}."
        return 0
    fi

    echo "Will delete ${#paths[@]} worktree(s) for ${REPO_NAME}:"
    printf '  %s\n' "${paths[@]#${REPO_WT_DIR}/}"
    echo
    read -rp "Continue? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; return 0; }

    local wt
    for wt in "${paths[@]}"; do
        cmd_delete "$wt"
    done
}

if [[ $# -eq 0 ]]; then
    show_help
    exit 0
fi

case "${1:-}" in
    -h|--help)
        show_help
        ;;
    new)
        shift
        cmd_new "$@"
        ;;
    pr)
        shift
        cmd_pr "$@"
        ;;
    open)
        shift
        cmd_open "$@"
        ;;
    path)
        shift
        cmd_path "$@"
        ;;
    pick)
        shift
        cmd_pick "$@"
        ;;
    title)
        shift
        cmd_title "$@"
        ;;
    list)
        shift
        cmd_list "$@"
        ;;
    delete)
        shift
        cmd_delete "$@"
        ;;
    clean)
        shift
        cmd_clean "$@"
        ;;
    cs)
        shift
        cmd_cs "$@"
        ;;
    *)
        error "Unknown command '${1:-}'"
        echo "Run 'ws --help' for usage" >&2
        exit 1
        ;;
esac
