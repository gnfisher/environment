#!/usr/bin/env bash
set -euo pipefail

private_dir="${XDG_CONFIG_HOME:-$HOME/.config}/environment"
ref_file="$private_dir/splunk-token.op-ref"
bash_env="$private_dir/splunk-token.bash"
fish_env="$private_dir/splunk-token.fish"
docker_env="$private_dir/splunk-token.env"

usage() {
    cat <<'USAGE'
Usage:
  refresh-splunk-token [op://vault/item/field]
  refresh-splunk-token --from-env

Reads the Splunk bearer token from 1Password once and writes local private
shell env cache files:
  ~/.config/environment/splunk-token.bash
  ~/.config/environment/splunk-token.fish
  ~/.config/environment/splunk-token.env

If no 1Password reference is passed, the script uses:
  1. $SPLUNK_BEARER_TOKEN_OP_REF
  2. ~/.config/environment/splunk-token.op-ref
USAGE
}

shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

mkdir -p "$private_dir"
chmod 700 "$private_dir"

ref="${1:-${SPLUNK_BEARER_TOKEN_OP_REF:-}}"
if [[ -z "$ref" && -r "$ref_file" ]]; then
    ref="$(<"$ref_file")"
fi

if [[ "${1:-}" == "--from-env" ]]; then
   token="${SPLUNK_BEARER_TOKEN:-}"
   if [[ -z "$token" ]]; then
       echo "refresh-splunk-token: SPLUNK_BEARER_TOKEN is not set" >&2
       exit 1
   fi
elif [[ -z "$ref" ]]; then
   usage >&2
   exit 2
else
   if ! command -v op >/dev/null 2>&1; then
       echo "refresh-splunk-token: 1Password CLI 'op' not found in PATH" >&2
       exit 1
   fi

   token="$(op read "$ref")"
   if [[ -z "$token" ]]; then
       echo "refresh-splunk-token: 1Password returned an empty token" >&2
       exit 1
   fi

   printf '%s\n' "$ref" > "$ref_file"
   chmod 600 "$ref_file"
fi

quoted_token="$(shell_quote "$token")"

{
    echo "# Generated by refresh-splunk-token. Do not commit."
    echo "export SPLUNK_BEARER_TOKEN=$quoted_token"
} > "$bash_env"

{
    echo "# Generated by refresh-splunk-token. Do not commit."
    echo "set -gx SPLUNK_BEARER_TOKEN $quoted_token"
} > "$fish_env"

{
    echo "# Generated by refresh-splunk-token. Do not commit."
    echo "SPLUNK_BEARER_TOKEN=$token"
} > "$docker_env"

chmod 600 "$bash_env" "$fish_env" "$docker_env"

echo "Wrote Splunk token cache:"
echo "  $bash_env"
echo "  $fish_env"
echo "  $docker_env"
