#!/bin/bash
# Re-authenticate gh CLI with a personal access token or the Codespace GITHUB_TOKEN.
# Reads from ~/.gh-pat if present, otherwise falls back to GITHUB_TOKEN env var.

set -e

PAT_FILE="$HOME/.gh-pat"

if [[ -f "$PAT_FILE" ]]; then
    token="$(cat "$PAT_FILE")"
    if [[ -z "$token" ]]; then
        echo "Error: $PAT_FILE exists but is empty" >&2
        exit 1
    fi
    unset GITHUB_TOKEN
    printf "%s" "$token" | gh auth login --with-token
    echo "✅ gh auth updated with token from $PAT_FILE"
elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
    token="$GITHUB_TOKEN"
    unset GITHUB_TOKEN
    printf "%s" "$token" | gh auth login --with-token
    echo "✅ gh auth updated with current GITHUB_TOKEN"
else
    echo "Error: no ~/.gh-pat file and GITHUB_TOKEN is not set" >&2
    exit 1
fi
