{
  "allowedUrls": [
    "https://docs.github.com",
    "https://raw.githubusercontent.com",
    "https://gist.github.com",
    "https://gist.githubusercontent.com",
    "https://github.com"
  ],
  "enabledPlugins": {
    "slack-mcp@github-slack-mcp": true,
    "port@agent-config": true,
    "plannotator-copilot@plannotator": true,
    "mattpocock-skills@mattpocock": true
  },
  "experimental": true,
  "exportSessions": false,
  "extraKnownMarketplaces": {
    "github-slack-mcp": {
      "source": {
        "source": "github",
        "repo": "github/copilot-slack-mcp"
      }
    },
    "agent-config": {
      "source": {
        "source": "github",
        "repo": "github/agent-skills"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "mattpocock": {
      "source": {
        "source": "github",
        "repo": "mattpocock/skills"
      }
    }
  },
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash '/Users/gnfisher/.copilot/hooks/herdr-agent-state.sh'",
        "timeoutSec": 10,
        "_vsCodeCompat": "SessionStart"
      }
    ]
  },
  "ide": {
    "autoConnect": true
  },
  "logLevel": "all",
  "remoteSessions": false,
  "renderMarkdown": true,
  "screenReader": false,
  "sessionSync": [
    {
      "level": "local",
      "origin": "*"
    }
  ],
  "showReasoning": false,
  "steerableSessions": false,
  "storeSessionsRemotely": false,
  "theme": "default",
  "undo_without_confirmation": true,
  "model": "gpt-5.6-sol",
  "effortLevel": "high",
  "sandbox": {
    "enabled": false,
    "sandboxMcpServers": true,
    "sandboxLspServers": true,
    "allowBypass": true,
    "gitAuth": true,
    "ghAuth": true,
    "userPolicy": {
      "network": {
        "allowLocalNetwork": true
      }
    }
  }
}
